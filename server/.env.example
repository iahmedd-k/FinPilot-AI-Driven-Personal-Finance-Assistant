PORT=5000
NODE_ENV=development

MONGO_URI=mongodb+srv://finpilot-ai:finpilot-ai-admin@cluster0.xibcuto.mongodb.net/finpilot?retryWrites=true&w=majority

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Groq (for AI features)
# - Set to your Groq API key (from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Stripe (billing)
# - Replace with your live secret key for production
# - Do NOT commit real secret keys into source control
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PRICE_ID_PRO=your_stripe_price_id_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_TRIAL_DAYS=0

CLIENT_URL=http://localhost:5173

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email_here
EMAIL_PASS=your_app_password
VITE_API_URL=http://localhost:5000/api